# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
.env*.local

# Hojas del builder (fallback local; en prod se usa Supabase)
data/characters/

# imagenes generadas en dev local
/public/galeria/

# PNG originales de la galeria (pesados; en el repo van los .jpg optimizados)
/public/datas-vaegrant/*.png
/public/datas-vaegrant/**/*.png

# Imágenes de referencia de terceros (estilo L'Éther); no van al repo
/public/examples/

# Imágenes fuente de sesiones de Vaegrant (originales PNG + 4K pesados):
# fuera del repo; se optimizan a JPG en /public/vaegrant-galeria (eso sí va).
/sources/Vaegrant/**/Images/

# Sesiones: audios y backups crudos NO se commitean (los .txt de transcripción sí)
/sources/Vaegrant/**/images/
/sources/Vaegrant/**/*.ogg
/sources/Vaegrant/**/*.ogg.json
